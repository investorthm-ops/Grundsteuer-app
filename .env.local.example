# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service-role key (introduced with PROJ-12).
# Used ONLY server-side for:
#   - writing to admin_audit_log (RLS-locked table; service role is the only writer)
#   - inviting new users via supabase.auth.admin.inviteUserByEmail
# MUST NEVER carry the NEXT_PUBLIC_ prefix and MUST never be referenced
# from client components or browser-bundled code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
