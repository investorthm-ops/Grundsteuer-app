# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Note: SUPABASE_SERVICE_ROLE_KEY is intentionally NOT used.
# All server-side access goes through the user's session via @supabase/ssr,
# and authorization is enforced by Row Level Security + the user_roles table.
# Adding a service-role key would bypass RLS and is not required for this app.

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
